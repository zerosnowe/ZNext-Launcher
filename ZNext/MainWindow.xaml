<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ZNext.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ZNext Launcher">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <TitleBar x:Name="AppTitleBar" Title="ZNext Launcher" Height="48" IsBackButtonVisible="False">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/Square44x44Logo.altform-unplated_targetsize-48.png"/>
            </TitleBar.IconSource>
            <TitleBar.LeftHeader>
                <Button x:Name="TitleBarBackButton"
                        Width="32"
                        Height="32"
                        Margin="8,0,0,0"
                        Padding="0"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Click="TitleBarBackButton_Click">
                    <FontIcon x:Name="TitleBarBackIcon" Glyph="&#xE72B;" FontFamily="{ThemeResource AppSymbolFontFamily}" FontSize="12"/>
                </Button>
            </TitleBar.LeftHeader>
            <TitleBar.RightHeader>
                <Button x:Name="TitleBarUserButton"
                        Width="36"
                        Height="36"
                        Margin="0,0,4,0"
                        Padding="0"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Right">
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <StackPanel MinWidth="220"
                                        MaxWidth="280"
                                        Padding="10"
                                        Spacing="8">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Grid Width="36" Height="36">
                                        <PersonPicture x:Name="TitleBarFlyoutAvatarPicture"
                                                       Width="36"
                                                       Height="36"
                                                       Visibility="Collapsed"/>
                                        <Border Width="36"
                                                Height="36"
                                                CornerRadius="18"
                                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                Visibility="Visible"
                                                x:Name="TitleBarFlyoutUserGlyphHost">
                                            <FontIcon x:Name="TitleBarFlyoutUserGlyph"
                                                      Glyph="&#xE77B;"
                                                      FontFamily="{ThemeResource AppSymbolFontFamily}"
                                                      FontSize="16"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                        <TextBlock x:Name="TitleBarFlyoutUsernameText"
                                                   Text="未登录"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="TitleBarFlyoutEmailText"
                                                   Text="-"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>

                                <Button Content="退出登录"
                                        HorizontalAlignment="Left"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#0057D8"
                                        Click="TitleBarLogoutMenuItem_Click"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                    <Grid Width="28" Height="28">
                        <PersonPicture x:Name="TitleBarAvatarPicture"
                                       Width="28"
                                       Height="28"
                                       Visibility="Collapsed"/>
                        <FontIcon x:Name="TitleBarUserGlyph"
                                  Glyph="&#xE77B;"
                                  FontFamily="{ThemeResource AppSymbolFontFamily}"
                                  FontSize="16"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </Button>
            </TitleBar.RightHeader>
        </TitleBar>

        <InfoBar Grid.RowSpan="2"
                 x:Name="TopSuccessInfoBar"
                 Margin="0,0,20,20"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 MinWidth="260"
                 MaxWidth="360"
                 IsOpen="False"
                 IsClosable="False"
                 IsIconVisible="True"
                 Severity="Success"
                 Message="操作成功"
                 Canvas.ZIndex="9999">
        </InfoBar>

        <Grid Grid.RowSpan="2"
              x:Name="StartupLoadingOverlay"
              Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
              Opacity="1"
              Canvas.ZIndex="9998">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="20">
                <Image x:Name="StartupLoadingIconImage"
                       Source="ms-appx:///Assets/Square44x44Logo.altform-unplated_targetsize-256.png"
                       Width="168"
                       Height="168"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"/>
                <ProgressRing x:Name="StartupLoadingRing"
                              Width="34"
                              Height="34"
                              IsActive="True"
                              HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid Grid.RowSpan="2"
              x:Name="SecurityLockOverlay"
              Visibility="Collapsed"
              Background="#EFF2F6"
              Canvas.ZIndex="10000">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="14"
                        Width="360">
                <Border Width="180"
                        Height="180"
                        CornerRadius="90"
                        Background="#1F7AE0"
                        HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE72E;"
                              FontFamily="{ThemeResource AppSymbolFontFamily}"
                              FontSize="96"
                              Foreground="White"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="安全访问"
                           FontSize="48"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="请证明您的身份以访问应用"
                           FontSize="18"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <PasswordBox x:Name="SecurityUnlockPasswordBox"
                             PlaceholderText="输入您的密码"
                             Width="320"
                             FontSize="16"
                             PasswordRevealMode="Peek"
                             KeyDown="SecurityUnlockPasswordBox_KeyDown"/>
                <TextBlock x:Name="SecurityUnlockErrorText"
                           Text=""
                           Foreground="#C42B1C"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Visibility="Collapsed"/>
                <Button Content="使用密码登录"
                        Width="140"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Center"
                        Click="SecurityUnlockButton_Click"/>
            </StackPanel>
        </Grid>

        <NavigationView Grid.Row="1" x:Name="NavView" IsSettingsVisible="False" IsBackEnabled="False"
                        IsBackButtonVisible="Collapsed"
                        PaneDisplayMode="Auto"
                        IsPaneToggleButtonVisible="True"
                        CompactPaneLength="48"
                        OpenPaneLength="240"
                        SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="首页"
                                    Tag="Home">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{ThemeResource AppSymbolFontFamily}" Glyph="&#xE80F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="隧道管理"
                                    Tag="Tunnels">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{ThemeResource AppSymbolFontFamily}" Glyph="&#xE81B;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="创建隧道"
                                    Tag="CreateTunnel">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{ThemeResource AppSymbolFontFamily}" Glyph="&#xE724;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="节点状态"
                                    Tag="Nodes">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{ThemeResource AppSymbolFontFamily}" Glyph="&#xE95A;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="帮助中心"
                                    Tag="Help">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{ThemeResource AppSymbolFontFamily}" Glyph="&#xE776;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="控制台"
                                    Tag="Console">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{ThemeResource AppSymbolFontFamily}" Glyph="&#xE756;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="设置"
                                    Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon FontFamily="{ThemeResource AppSymbolFontFamily}" Glyph="&#xE713;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>
            
            <Grid>
                <ScrollViewer x:Name="MainContentScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              Visibility="Visible"
                              IsHitTestVisible="True">
                    <Grid x:Name="ScrolledSectionFrameHost">
                        <Grid x:Name="SectionFrame"
                              Margin="20">
                            <Grid.ChildrenTransitions>
                                <TransitionCollection>
                                    <EntranceThemeTransition FromVerticalOffset="24" />
                                </TransitionCollection>
                            </Grid.ChildrenTransitions>
                        </Grid>
                    </Grid>
                </ScrollViewer>
                <Grid x:Name="DirectSectionFrameHost"
                      Visibility="Collapsed"/>
            </Grid>
        </NavigationView>
    </Grid>
</Window>




