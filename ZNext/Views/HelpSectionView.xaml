<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ZNext.Views.HelpSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <StackPanel Spacing="20">
            <TextBlock Text="帮助中心" FontSize="28" FontWeight="SemiBold"/>

            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" MinHeight="190">
                    <Grid RowDefinitions="*,Auto" RowSpacing="14">
                        <StackPanel Spacing="10">
                            <Border Background="#E8F3FF" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left">
                                <TextBlock Text="推荐" Foreground="#1D4ED8" FontSize="12"/>
                            </Border>
                            <TextBlock Text="官方 QQ 一群" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="加入用户交流群获取帮助，与其他用户交流使用经验，快速解决问题。"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                            <Button Content="加入 QQ 群"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Tag="https://qm.qq.com/q/XX6tpcvNo4"
                                    Click="OpenLinkButton_Click"/>
                            <Button Content="复制群号"
                                    Tag="1019501085"
                                    Click="CopyTextButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="0" Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" MinHeight="190">
                    <Grid RowDefinitions="*,Auto" RowSpacing="14">
                        <StackPanel Spacing="10">
                            <Border Background="#E8F3FF" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left">
                                <TextBlock Text="推荐" Foreground="#1D4ED8" FontSize="12"/>
                            </Border>
                            <TextBlock Text="官方 QQ 二群" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="加入用户交流群获取帮助，与其他用户交流使用经验，快速解决问题。"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                            <Button Content="加入 QQ 群"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Tag="https://qm.qq.com/q/fBtW7lJ1Xa"
                                    Click="OpenLinkButton_Click"/>
                            <Button Content="复制群号"
                                    Tag="708797546"
                                    Click="CopyTextButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" MinHeight="190">
                    <Grid RowDefinitions="*,Auto" RowSpacing="14">
                        <StackPanel Spacing="10">
                            <Border Background="#FEF3C7" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left">
                                <TextBlock Text="慢速" Foreground="#B45309" FontSize="12"/>
                            </Border>
                            <TextBlock Text="用户支持邮箱" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="适合需要详细描述的问题和建议，我们会认真处理每一封邮件。"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Row="1"
                                Content="发送邮件"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Left"
                                Tag="mailto:support@mefrp.com"
                                Click="OpenLinkButton_Click"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" MinHeight="190">
                    <Grid RowDefinitions="*,Auto" RowSpacing="14">
                        <StackPanel Spacing="10">
                            <Border Background="#FEE2E2" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left">
                                <TextBlock Text="暂不可用" Foreground="#B91C1C" FontSize="12"/>
                            </Border>
                            <TextBlock Text="企业微信群" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="当前不可用。"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Row="1"
                                Content="暂不可用"
                                HorizontalAlignment="Left"
                                IsEnabled="False"/>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" MinHeight="190">
                    <Grid RowDefinitions="*,Auto" RowSpacing="14">
                        <StackPanel Spacing="10">
                            <Border Background="#DCFCE7" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left">
                                <TextBlock Text="推荐" Foreground="#166534" FontSize="12"/>
                            </Border>
                            <TextBlock Text="飞书群" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="加入飞书群获取帮助。"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Row="1"
                                Content="加入飞书群"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Left"
                                Tag="https://applink.feishu.cn/client/chat/chatter/add_by_link?link_token=874l3500-4e85-4a04-a4b4-cbc02945de90"
                                Click="OpenLinkButton_Click"/>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" MinHeight="190">
                    <Grid RowDefinitions="*,Auto" RowSpacing="14">
                        <StackPanel Spacing="10">
                            <Border Background="#DCFCE7" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left">
                                <TextBlock Text="全面" Foreground="#166534" FontSize="12"/>
                            </Border>
                            <TextBlock Text="官方文档" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="文档详尽，覆盖全面，包含详细使用说明和常见问题。"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Row="1"
                                Content="查看文档"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Left"
                                Tag="https://www.mefrp.com/docs"
                                Click="OpenLinkButton_Click"/>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Grid.ColumnSpan="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16" MinHeight="170">
                    <Grid RowDefinitions="*,Auto" RowSpacing="14">
                        <StackPanel Spacing="10">
                            <Border Background="#E0E7FF" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left">
                                <TextBlock Text="扩展" Foreground="#3730A3" FontSize="12"/>
                            </Border>
                            <TextBlock Text="第三方客户端" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="基于 ME Frp OpenAPI 的第三方客户端和集成方案。"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Row="1"
                                Content="查看客户端"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Left"
                                Tag="https://www.mefrp.com/dashboard/3rdparty-clients"
                                Click="OpenLinkButton_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
