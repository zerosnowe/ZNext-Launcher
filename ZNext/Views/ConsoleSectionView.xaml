<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ZNext.Views.ConsoleSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <StackPanel Spacing="12">
            <TextBlock Text="控制台" FontSize="28" FontWeight="SemiBold"/>
            <TextBlock x:Name="ConsolePathText"
                       x:FieldModifier="public"
                       Text="工作目录: -"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <Grid ColumnDefinitions="220,*" ColumnSpacing="12" MinHeight="520">
                <NavigationView Grid.Column="0"
                                x:Name="ConsoleSessionsNavView"
                                x:FieldModifier="public"
                                IsSettingsVisible="False"
                                IsBackEnabled="False"
                                IsBackButtonVisible="Collapsed"
                                IsPaneToggleButtonVisible="False"
                                PaneDisplayMode="Left"
                                IsPaneOpen="True"
                                OpenPaneLength="220"
                                CompactPaneLength="48"
                                SelectionChanged="ConsoleSessionsNavView_SelectionChanged">
                    <NavigationView.PaneHeader>
                        <TextBlock Text="会话列表"
                                   Margin="12,8,0,8"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </NavigationView.PaneHeader>
                    <Grid/>
                </NavigationView>

                <Border Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10">
                    <Grid RowDefinitions="*,Auto" RowSpacing="10">
                        <Grid>
                            <ScrollViewer x:Name="ConsoleOutputScrollViewer"
                                          x:FieldModifier="public"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Hidden"
                                          HorizontalScrollMode="Disabled">
                                <RichTextBlock x:Name="ConsoleOutputRichText"
                                               x:FieldModifier="public"
                                               IsTextSelectionEnabled="True"
                                               TextWrapping="NoWrap"
                                               FontFamily="Consolas"
                                               FontSize="13"/>
                            </ScrollViewer>
                        </Grid>

                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                            <TextBox x:Name="ConsoleInputTextBox"
                                     x:FieldModifier="public"
                                     PlaceholderText="输入 PowerShell 命令，回车执行"
                                     KeyDown="ConsoleInputTextBox_KeyDown"/>
                            <Button Grid.Column="1"
                                    x:Name="ConsoleRunButton"
                                    x:FieldModifier="public"
                                    Content="执行"
                                    MinWidth="88"
                                    Click="ConsoleRunButton_Click"/>
                            <Button Grid.Column="2"
                                    x:Name="ConsoleInterruptButton"
                                    x:FieldModifier="public"
                                    Content="Ctrl+C"
                                    MinWidth="88"
                                    Click="ConsoleInterruptButton_Click"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
