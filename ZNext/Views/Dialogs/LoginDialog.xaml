<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="ZNext.Views.Dialogs.LoginDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:binding="using:ZNext.Infrastructure.Binding"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="using:ZNext.ViewModels.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="登录账户"
    PrimaryButtonText="登录"
    CloseButtonText="取消"
    DefaultButton="Primary"
    PrimaryButtonStyle="{ThemeResource AccentButtonStyle}"
    Style="{ThemeResource DefaultContentDialogStyle}"
    d:DataContext="{d:DesignInstance Type=dialogs:LoginDialogViewModel}"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollMode="Disabled"
                  VerticalScrollMode="Auto"
                  MaxHeight="620">
        <Border Width="372"
                MaxWidth="520"
                Padding="0,0,0,8">
            <StackPanel Spacing="14">
                <StackPanel Spacing="4">
                    <TextBlock Text="ME Frp 账户登录"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="输入账号密码并完成人机验证后登录。"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="UsernameTextBox"
                             Grid.Row="0"
                             Header="用户名或邮箱"
                             PlaceholderText="输入您的用户名或邮箱"
                             HorizontalAlignment="Stretch"
                             Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <PasswordBox x:Name="PasswordBox"
                                 Grid.Row="1"
                                 Header="密码"
                                 PlaceholderText="输入您的密码"
                                 HorizontalAlignment="Stretch"
                                 PasswordRevealMode="Peek"
                                 binding:PasswordBoxBinding.Password="{Binding Password, Mode=TwoWay}"/>
                </Grid>

                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="人机验证"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="开始验证"
                                    MinWidth="96"
                                    Height="32"
                                    Command="{Binding OpenCaptchaCommand}"/>
                        </Grid>

                        <TextBox x:Name="CaptchaInputTextBox"
                                 Header="验证码（支持粘贴 Base64 自动解码）"
                                 PlaceholderText="完成验证后粘贴"
                                 HorizontalAlignment="Stretch"
                                 Text="{Binding CaptchaInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="{Binding CaptchaStatusText, Mode=OneWay}"
                                   FontSize="12"
                                   Foreground="{Binding CaptchaStatusBrush, Mode=OneWay}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <CheckBox Content="记住用户名"
                          IsChecked="{Binding RememberMe, Mode=TwoWay}"/>

                <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}"
                           Foreground="{ThemeResource SystemErrorTextColor}"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorVisibility, Mode=OneWay}"/>

                <ProgressBar IsIndeterminate="True"
                             Visibility="{Binding ProgressVisibility, Mode=OneWay}"
                             Height="4"/>
            </StackPanel>
        </Border>
    </ScrollViewer>
</ContentDialog>
