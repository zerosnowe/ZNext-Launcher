<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ZNext.Views.Dialogs.AnimatedDialogContent"
    x:Name="RootControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="AnimatedDialogContent_Loaded"
    Opacity="0">

    <UserControl.Resources>
        <Storyboard x:Name="OpenStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootControl"
                             Storyboard.TargetProperty="Opacity"
                             To="1"
                             Duration="0:0:0.14"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="Root">
        <ContentPresenter x:Name="BodyPresenter"/>
    </Grid>
</UserControl>
