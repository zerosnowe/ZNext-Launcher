<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ZNext.Views.TunnelsSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    SizeChanged="TunnelsSectionView_SizeChanged">
    <Grid>
        <StackPanel Spacing="20">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="隧道管理" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center"/>

                <TextBox Grid.Column="1"
                         x:Name="TunnelSearchBox"
                         x:FieldModifier="public"
                         PlaceholderText="搜索隧道..."
                         TextChanged="TunnelSearchBox_TextChanged"
                         Width="230"
                         Height="34"
                         VerticalAlignment="Center"
                         VerticalContentAlignment="Center"
                         FontSize="13"/>

                <Border Grid.Column="2"
                        Width="70"
                        Height="34"
                        BorderThickness="1"
                        CornerRadius="{ThemeResource ControlCornerRadius}"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        Padding="2,1"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <ToggleButton x:Name="TunnelGridModeButton"
                                      x:FieldModifier="public"
                                      Width="31"
                                      Height="30"
                                      IsChecked="True"
                                      Click="TunnelGridModeButton_Click"
                                      CornerRadius="{ThemeResource ControlCornerRadius}"
                                      Padding="0"
                                      ToolTipService.ToolTip="网格视图">
                            <FontIcon Glyph="&#xE80A;"
                                      FontFamily="{ThemeResource AppSymbolFontFamily}"
                                      FontSize="12"/>
                        </ToggleButton>
                        <ToggleButton x:Name="TunnelListModeButton"
                                      x:FieldModifier="public"
                                      Width="31"
                                      Height="30"
                                      Click="TunnelListModeButton_Click"
                                      CornerRadius="{ThemeResource ControlCornerRadius}"
                                      Padding="0"
                                      ToolTipService.ToolTip="列表视图">
                            <FontIcon Glyph="&#xE8FD;"
                                      FontFamily="{ThemeResource AppSymbolFontFamily}"
                                      FontSize="12"/>
                        </ToggleButton>
                    </StackPanel>
                </Border>

                <Button Grid.Column="3"
                        x:Name="RefreshTunnelsButton"
                        x:FieldModifier="public"
                        Width="34"
                        Height="34"
                        CornerRadius="{ThemeResource ControlCornerRadius}"
                        Padding="0"
                        VerticalAlignment="Center"
                        Click="RefreshTunnelsButton_Click">
                    <FontIcon Glyph="&#xE72C;"
                              FontFamily="{ThemeResource AppSymbolFontFamily}"
                              FontSize="13"/>
                </Button>
            </Grid>

            <ProgressRing x:Name="TunnelsLoadingProgressBar"
                          x:FieldModifier="public"
                          IsActive="{Binding IsLoading}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                          Width="24"
                          Height="24"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>

            <StackPanel x:Name="TunnelsErrorPlaceholder"
                        x:FieldModifier="public"
                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Margin="0,18,0,6">
                <Image Source="ms-appx:///Assets/wifi.png"
                       Width="84"
                       Height="84"
                       Stretch="Uniform"/>
                <TextBlock Text="无法连接到服务，请检查网络"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button Content="重试"
                        Width="96"
                        HorizontalAlignment="Center"
                        Click="RetryTunnelsButton_Click"/>
            </StackPanel>

            <ItemsRepeater x:Name="TunnelsItemsRepeater"
                           x:FieldModifier="public"
                           ItemsSource="{Binding VisibleTunnels}"
                           Visibility="{Binding HasVisibleTunnels, Converter={StaticResource BooleanToVisibilityConverter}}"
                           HorizontalAlignment="Center">
                <ItemsRepeater.Layout>
                    <UniformGridLayout MinItemWidth="300"
                                       MinItemHeight="224"
                                       MinColumnSpacing="16"
                                       MinRowSpacing="16"
                                       ItemsJustification="Center"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="14" Padding="16" MinWidth="300" HorizontalAlignment="Stretch">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap"
                                              VerticalAlignment="Center"/>
                                    <Border Grid.Column="1"
                                            Padding="8,3"
                                            CornerRadius="10"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            Background="{Binding IsOnlineResolved, Converter={StaticResource BooleanToColorConverter}, ConverterParameter=Online}">
                                        <TextBlock Text="{Binding OnlineStatusText}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>
                                    <Border Grid.Column="2"
                                            Padding="8,3"
                                            CornerRadius="10"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            Background="#F59E0B"
                                            Visibility="{Binding IsDisabledResolved, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="禁用"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1F2937"/>
                                    </Border>
                                    <Button Grid.Column="3"
                                            Width="30"
                                            Height="30"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                        <Button.Flyout>
                                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                <MenuFlyoutItem Text="查看详情"
                                                                FontFamily="Microsoft YaHei UI"
                                                                Language="zh-CN"
                                                                Tag="{Binding}"
                                                                Click="TunnelViewDetailsMenuItem_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE946;" FontFamily="{ThemeResource AppSymbolFontFamily}"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem Text="编辑"
                                                                FontFamily="Microsoft YaHei UI"
                                                                Language="zh-CN"
                                                                Tag="{Binding}"
                                                                Click="TunnelEditMenuItem_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE70F;" FontFamily="{ThemeResource AppSymbolFontFamily}"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="启用隧道"
                                                                FontFamily="Microsoft YaHei UI"
                                                                Language="zh-CN"
                                                                Tag="{Binding}"
                                                                Click="TunnelEnableMenuItem_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE768;" FontFamily="{ThemeResource AppSymbolFontFamily}"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="强制下线"
                                                                FontFamily="Microsoft YaHei UI"
                                                                Language="zh-CN"
                                                                Tag="{Binding}"
                                                                Click="TunnelForceOfflineMenuItem_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE71A;" FontFamily="{ThemeResource AppSymbolFontFamily}"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem Text="删除"
                                                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                                FontFamily="Microsoft YaHei UI"
                                                                Language="zh-CN"
                                                                Tag="{Binding}"
                                                                Click="TunnelDeleteMenuItem_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon Glyph="&#xE74D;"
                                                                  FontFamily="{ThemeResource AppSymbolFontFamily}"
                                                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                        <FontIcon Glyph="&#xE712;" FontFamily="{ThemeResource AppSymbolFontFamily}" FontSize="14"/>
                                    </Button>
                                </Grid>

                                <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" RowSpacing="8" Margin="0,10,0,0">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <TextBlock Text="ID:" FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <Border Grid.Column="1"
                                                Background="#DCEBFF"
                                                CornerRadius="10"
                                                Padding="8,2"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding IdDisplayText}"
                                                       FontSize="12"
                                                       Foreground="#1967D2"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>

                                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <TextBlock Text="协议:" FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Type}"
                                                   FontSize="13"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    </Grid>

                                    <Grid Grid.Row="2" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <TextBlock Text="远程端口:" FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding remotePort}"
                                                   FontSize="13"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    </Grid>

                                    <Grid Grid.Row="3" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                        <TextBlock Text="节点:" FontSize="13" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding NodeDisplayText}"
                                                   FontSize="13"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>

                                    <StackPanel Grid.Row="5"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                        <ToggleSwitch Header=""
                                                      OffContent=""
                                                      OnContent=""
                                                      IsOn="{Binding IsLocalRunning, Mode=OneWay}"
                                                      Tag="{Binding}"
                                                      MinWidth="52"
                                                      Loaded="TunnelRunToggleSwitch_Loaded"
                                                      Toggled="TunnelRunToggleSwitch_Toggled"/>
                                        <Button Tag="{Binding}"
                                                Click="TunnelCopyLinkButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE8C8;" FontFamily="{ThemeResource AppSymbolFontFamily}" FontSize="12"/>
                                                <TextBlock Text="复制链接"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <TextBlock x:Name="NoTunnelsTextBlock"
                       x:FieldModifier="public"
                       Text="暂无隧道数据"
                       FontSize="16"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</UserControl>
