<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ZNext.Views.SettingsSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <Grid.Resources>
            <Style TargetType="toolkit:SettingsCard">
                <Setter Property="CornerRadius" Value="10"/>
            </Style>
            <Style TargetType="toolkit:SettingsExpander">
                <Setter Property="CornerRadius" Value="10"/>
            </Style>
        </Grid.Resources>

        <StackPanel x:Name="SettingsCardsStackPanel"
                    Spacing="6"
                    HorizontalAlignment="Stretch">
            <toolkit:SettingsCard Header="主题"
                                  Description="切换主题">
                <toolkit:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE790;"/>
                </toolkit:SettingsCard.HeaderIcon>
                <ComboBox MinWidth="160"
                          SelectedValue="{Binding ThemeMode, Mode=TwoWay}"
                          SelectedValuePath="Tag">
                    <ComboBoxItem Content="跟随系统" Tag="Default"/>
                    <ComboBoxItem Content="浅色" Tag="Light"/>
                    <ComboBoxItem Content="深色" Tag="Dark"/>
                </ComboBox>
            </toolkit:SettingsCard>

            <toolkit:SettingsCard Header="开机自启动"
                                  Description="允许跟随账户登录运行">
                <toolkit:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE7E8;"/>
                </toolkit:SettingsCard.HeaderIcon>
                <ToggleSwitch x:Name="AutoStartToggle"
                              IsOn="{Binding IsAutoStartEnabled, Mode=TwoWay}"
                              OffContent="关闭"
                              OnContent="开启"
                              Toggled="AutoStartToggle_Toggled"/>
            </toolkit:SettingsCard>

            <toolkit:SettingsExpander Header="隧道随应用启动"
                                      Description="跟随应用自动启动隧道"
                                      IsExpanded="False">
                <toolkit:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE7B5;"/>
                </toolkit:SettingsExpander.HeaderIcon>
                <toolkit:SettingsExpander.Content>
                    <ToggleSwitch x:Name="AutoStartTunnelsToggle"
                                  IsOn="{Binding IsAutoStartTunnelsEnabled, Mode=TwoWay}"
                                  OffContent="关闭"
                                  OnContent="开启"
                                  Toggled="AutoStartTunnelsToggle_Toggled"/>
                </toolkit:SettingsExpander.Content>
                <toolkit:SettingsExpander.Items>
                    <toolkit:SettingsCard Header="自动启动隧道列表"
                                          Description="勾选后将在应用启动时自动启动">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE7AD;"/>
                        </toolkit:SettingsCard.HeaderIcon>
                        <StackPanel Spacing="8" MinWidth="320">
                            <TextBlock x:Name="AutoStartTunnelListStatusText"
                                       x:FieldModifier="public"
                                       Text="正在加载隧道列表..."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <ScrollViewer MaxHeight="220">
                                <StackPanel x:Name="AutoStartTunnelCheckListPanel"
                                            x:FieldModifier="public"
                                            Spacing="4"/>
                            </ScrollViewer>
                        </StackPanel>
                    </toolkit:SettingsCard>
                </toolkit:SettingsExpander.Items>
            </toolkit:SettingsExpander>

            <toolkit:SettingsCard Header="头像设置"
                                  Description="上传本地头像">
                <toolkit:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE77B;"/>
                </toolkit:SettingsCard.HeaderIcon>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="上传头像"
                            MinWidth="120"
                            Click="UploadAvatarButton_Click"/>
                    <TextBlock x:Name="AvatarStatusText"
                               x:FieldModifier="public"
                               Text="未设置"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </toolkit:SettingsCard>

            <toolkit:SettingsExpander Header="frpc 管理"
                                      Description="核心管理与版本信息"
                                      IsExpanded="False">
                <toolkit:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE896;"/>
                </toolkit:SettingsExpander.HeaderIcon>
                <toolkit:SettingsExpander.Content>
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <ProgressRing x:Name="FrpcInstallBusyRing"
                                      x:FieldModifier="public"
                                      Width="14"
                                      Height="14"
                                      IsActive="False"
                                      Visibility="Collapsed"/>
                        <TextBlock x:Name="FrpcInstallBusyText"
                                   x:FieldModifier="public"
                                   Text="安装中"
                                   Visibility="Collapsed"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Button x:Name="FrpcInstallButton"
                                x:FieldModifier="public"
                                Content="安装核心"
                                MinWidth="120"
                                Click="FrpcInstallButton_Click"/>
                    </StackPanel>
                </toolkit:SettingsExpander.Content>
                <toolkit:SettingsExpander.Items>
                    <toolkit:SettingsCard Header="安装状态"
                                          Description="查看客户端核心状态">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon x:Name="FrpcStatusIcon"
                                      x:FieldModifier="public"
                                      Glyph="&#xE946;"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </toolkit:SettingsCard.HeaderIcon>
                        <TextBlock x:Name="FrpcVersionText"
                                   Text="{Binding FrpcStatusText}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1"/>
                    </toolkit:SettingsCard>
                    <toolkit:SettingsCard Header="查看核心目录"
                                          Description="打开核心目录">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE8B7;"/>
                        </toolkit:SettingsCard.HeaderIcon>
                        <Button MinWidth="110"
                                Click="FrpcOpenDirectoryButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE838;" FontSize="14"/>
                                <TextBlock Text="打开"/>
                            </StackPanel>
                        </Button>
                    </toolkit:SettingsCard>
                </toolkit:SettingsExpander.Items>
            </toolkit:SettingsExpander>

            <toolkit:SettingsExpander Header="安全访问"
                                      Description="配置密码访问保护"
                                      IsExpanded="False">
                <toolkit:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE72E;"/>
                </toolkit:SettingsExpander.HeaderIcon>
                <toolkit:SettingsExpander.Content>
                    <ToggleSwitch x:Name="SecurityPasswordToggle"
                                  IsOn="{Binding IsSecurityPasswordEnabled, Mode=TwoWay}"
                                  OffContent="关闭"
                                  OnContent="开启"
                                  Toggled="SecurityPasswordToggle_Toggled"/>
                </toolkit:SettingsExpander.Content>
                <toolkit:SettingsExpander.Items>
                    <toolkit:SettingsCard Header="密码管理"
                                          Description="设置或重置密码">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE1F6;"/>
                        </toolkit:SettingsCard.HeaderIcon>
                        <Button x:Name="SetSecurityPasswordButton"
                                Content="{Binding SecurityPasswordButtonText}"
                                MinWidth="120"
                                Click="SetSecurityPasswordButton_Click"/>
                    </toolkit:SettingsCard>
                </toolkit:SettingsExpander.Items>
            </toolkit:SettingsExpander>

            <toolkit:SettingsCard Header="关于信息"
                                  Description="应用版本">
                <toolkit:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE946;"/>
                </toolkit:SettingsCard.HeaderIcon>
                <TextBlock x:Name="AboutVersionText"
                           Text="{Binding AboutVersionText}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </toolkit:SettingsCard>

            <toolkit:SettingsCard Header="更新"
                                  Description="检测并获取更新">
                <toolkit:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE895;"/>
                </toolkit:SettingsCard.HeaderIcon>
                <Button x:Name="FetchUpdateButton"
                        Content="{Binding FetchUpdateButtonText}"
                        IsEnabled="{Binding IsFetchUpdateEnabled}"
                        MinWidth="120"
                        Click="FetchUpdateButton_Click"/>
            </toolkit:SettingsCard>
        </StackPanel>
    </Grid>
</UserControl>
