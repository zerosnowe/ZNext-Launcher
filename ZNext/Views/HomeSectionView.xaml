<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ZNext.Views.HomeSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Row="0"
                    Grid.Column="0"
                    Spacing="12"
                    Margin="0,0,0,20">
            <Border x:Name="HomeUserBannerCard"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,14">
                <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                    <Grid Width="72" Height="72" VerticalAlignment="Center">
                        <PersonPicture x:Name="HomeBannerAvatarPicture"
                                       x:FieldModifier="public"
                                       Width="72"
                                       Height="72"
                                       Visibility="Collapsed"/>
                        <Border x:Name="HomeBannerAvatarFallback"
                                x:FieldModifier="public"
                                Width="72"
                                Height="72"
                                CornerRadius="36"
                                Background="{ThemeResource ControlFillColorSecondaryBrush}">
                            <FontIcon Glyph="&#xE77B;"
                                      FontFamily="{ThemeResource AppSymbolFontFamily}"
                                      FontSize="28"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Column="1" Margin="14,0,0,0" Spacing="4" VerticalAlignment="Center">
                        <TextBlock x:Name="HomeBannerUsernameText"
                                   Text="{Binding UsernameText}"
                                   FontSize="24"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="HomeBannerEmailText"
                                   Text="{Binding EmailText}"
                                   FontSize="14"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="HomeBannerUserIdText"
                                   Text="{Binding BannerUserIdText}"
                                   FontSize="14"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <Button x:Name="HomeBannerAnnouncementButton"
                                    Width="44"
                                    Height="44"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Click="HomeBannerAnnouncementButton_Click">
                                <Button.Resources>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    </Style>
                                </Button.Resources>
                                <FontIcon Glyph="&#xE789;" FontFamily="{ThemeResource AppSymbolFontFamily}" FontSize="16"/>
                            </Button>
                            <TextBlock Text="公告"
                                       FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <Button x:Name="HomeBannerSignInButton"
                                    Width="44"
                                    Height="44"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    IsEnabled="{Binding IsSignInEnabled}"
                                    Click="HomeBannerSignInButton_Click">
                                <Button.Resources>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    </Style>
                                </Button.Resources>
                                <FontIcon Glyph="&#xE8FB;" FontFamily="{ThemeResource AppSymbolFontFamily}" FontSize="16"/>
                            </Button>
                            <TextBlock Text="签到"
                                       FontSize="13"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid ColumnSpacing="16" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="HomeTunnelCountCard"
                        Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14"
                        Width="320"
                        HorizontalAlignment="Left"
                        MinHeight="130">
                    <Grid>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top">
                            <FontIcon Glyph="&#xE71D;"
                                      FontFamily="{ThemeResource AppSymbolFontFamily}"
                                      FontSize="18"
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="隧道数量"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="4"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom">
                            <TextBlock x:Name="HomeTunnelUsedText"
                                       Text="{Binding HomeTunnelUsedText}"
                                       FontSize="56"
                                       FontWeight="Bold"
                                       LineHeight="56"/>
                            <TextBlock Text="/"
                                       FontSize="56"
                                       FontWeight="Bold"
                                       LineHeight="56"/>
                            <TextBlock x:Name="HomeTunnelMaxText"
                                       Text="{Binding HomeTunnelMaxText}"
                                       FontSize="28"
                                       Margin="0,0,0,7"
                                       VerticalAlignment="Bottom"/>
                        </StackPanel>
                        <Border x:Name="HomeTunnelCountLoadingBadge"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="8,4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Visibility="{Binding IsTunnelCountLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <ProgressRing x:Name="HomeTunnelCountLoadingRing"
                                              Width="14"
                                              Height="14"
                                              IsActive="{Binding IsTunnelCountLoading}"/>
                                <TextBlock Text="加载中"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="HomeUserGroupCard"
                        Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14"
                        Width="320"
                        HorizontalAlignment="Left"
                        MinHeight="130">
                    <Grid>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top">
                            <FontIcon Glyph="&#xE902;"
                                      FontFamily="{ThemeResource AppSymbolFontFamily}"
                                      FontSize="18"
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="用户组"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="HomeUserGroupText"
                                   Text="{Binding HomeUserGroupText}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   Visibility="{Binding HomeUserGroupTextVisibility}"/>
                        <Image x:Name="HomeUserGroupOfficialImage"
                               Width="136"
                               Height="42"
                               Stretch="Uniform"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               Visibility="{Binding HomeUserGroupOfficialVisibility}"
                               Source="ms-appx:///Assets/正式用户.png"/>
                    </Grid>
                </Border>

                <Border x:Name="HomeTrafficStatsCard"
                        Grid.Column="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14"
                        MinWidth="320"
                        HorizontalAlignment="Stretch"
                        MinHeight="130">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top">
                            <FontIcon Glyph="&#xE9D2;"
                                      FontFamily="{ThemeResource AppSymbolFontFamily}"
                                      FontSize="18"
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="统计流量"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   x:Name="HomeTrafficStatsSubtitleText"
                                   Text="{Binding HomeTrafficStatsSubtitleText}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                </Border>
            </Grid>

            <Grid ColumnSpacing="16" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="HomeRealnameCard"
                        Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14"
                        Width="320"
                        HorizontalAlignment="Left"
                        MinHeight="130">
                    <Grid>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top">
                            <FontIcon Glyph="&#xE72E;"
                                      FontFamily="{ThemeResource AppSymbolFontFamily}"
                                      FontSize="18"
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="实名认证"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border x:Name="RealnameBadge"
                                Background="{Binding RealnameBadgeBackground}"
                                CornerRadius="10"
                                Padding="10,3"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom">
                            <TextBlock x:Name="RealnameText"
                                       Text="{Binding RealnameText}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding RealnameTextForeground}"/>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="HomeRegTimeCard"
                        Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14"
                        Width="320"
                        HorizontalAlignment="Left"
                        MinHeight="130">
                    <Grid>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top">
                            <FontIcon Glyph="&#xE823;"
                                      FontFamily="{ThemeResource AppSymbolFontFamily}"
                                      FontSize="18"
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="注册时间"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="RegTimeText"
                                   Text="{Binding RegTimeText}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"/>
                    </Grid>
                </Border>

                <Border x:Name="SystemStatusCard"
                        Grid.Column="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14"
                        MinWidth="320"
                        HorizontalAlignment="Stretch"
                        MinHeight="130">
                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Ellipse x:Name="SystemStatusDot" Width="8" Height="8" Fill="{Binding SystemStatusBrush}"/>
                                <TextBlock x:Name="SystemStatusTitleText"
                                           Text="{Binding SystemStatusTitle}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{Binding SystemStatusBrush}"/>
                            </StackPanel>
                            <TextBlock x:Name="SystemStatusRemarkText"
                                       Margin="16,0,0,0"
                                       Text="{Binding SystemStatusRemark}"
                                       FontSize="13"
                                       Foreground="{Binding SystemStatusBrush}"
                                       TextWrapping="Wrap"
                                       MaxLines="2"/>
                        </StackPanel>
                        <FontIcon x:Name="SystemStatusIcon"
                                  Grid.Column="1"
                                  Glyph="{Binding SystemStatusIconGlyph}"
                                  FontSize="20"
                                  Foreground="{Binding SystemStatusBrush}"
                                  VerticalAlignment="Center"
                                  Margin="12,0,0,0"/>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20">

                <StackPanel Spacing="4" Visibility="Collapsed">
                    <TextBlock x:Name="WelcomeText" Text="{Binding WelcomeText}" FontSize="26" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                    <TextBlock Text="用户信息" FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Left"/>
                </StackPanel>

                <Border x:Name="ImportantAnnouncementCard"
                        Visibility="{Binding ImportantAnnouncementVisibility}"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                            <Border Width="18" Height="18" CornerRadius="9" Background="#F59E0B" VerticalAlignment="Center">
                                <TextBlock Text="!" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Margin="8,0,0,0"
                                       Text="重要公告"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <Button Grid.Column="2"
                                    Width="28"
                                    Height="28"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    HorizontalAlignment="Right"
                                    Click="CloseImportantAnnouncementButton_Click">
                                <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Button>
                        </Grid>

                        <TextBlock x:Name="ImportantAnnouncementTitleText"
                                   Text="{Binding ImportantAnnouncementTitle}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   TextWrapping="Wrap"/>

                        <RichTextBlock x:Name="ImportantAnnouncementBodyRichTextBlock"
                                       x:FieldModifier="public"
                                       IsTextSelectionEnabled="True"
                                       TextWrapping="Wrap"
                                       IsColorFontEnabled="True"/>
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20"
                        Visibility="Collapsed">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="24" RowSpacing="14">
                        <StackPanel Grid.Column="0" Spacing="14">
                            <StackPanel Spacing="4">
                                <TextBlock Text="用户名" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="UsernameText" Text="{Binding UsernameText}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="隧道数量" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="ProxyCountText" Text="{Binding ProxyCountText}" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="入站带宽" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="InBoundText" Text="{Binding InBoundText}" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="签到" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button x:Name="SignInButton"
                                            Content="{Binding SignInButtonText}"
                                            Height="30"
                                            MinWidth="72"
                                            IsEnabled="{Binding IsSignInEnabled}"
                                            Click="SignInButton_Click"/>
                                    <TextBlock x:Name="TodaySignedText" Text="{Binding TodaySignedText}" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="14">
                            <StackPanel Spacing="4">
                                <TextBlock Text="用户 ID" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Border Background="#FEF3C7" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left">
                                    <TextBlock x:Name="UserIdText" Text="{Binding UserIdText}" FontSize="12" Foreground="#B45309"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="用户组" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Border Background="#DBEAFE" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left">
                                    <TextBlock x:Name="LevelText" Text="{Binding LevelText}" FontSize="12" Foreground="#1D4ED8"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="注册邮箱" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="EmailText" Text="{Binding EmailText}" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="剩余流量" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="TrafficText" Text="{Binding TrafficText}" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="出站带宽" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="OutBoundText" Text="{Binding OutBoundText}" FontSize="14"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Button x:Name="LoginButton"
                        x:FieldModifier="public"
                        Content="登录账户"
                        HorizontalAlignment="Stretch"
                        Height="44"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="LoginButton_Click"/>

                <Button x:Name="LogoutButton"
                        x:FieldModifier="public"
                        Content="退出登录"
                        HorizontalAlignment="Stretch"
                        Height="44"
                        Visibility="Collapsed"
                        Click="LogoutButton_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
