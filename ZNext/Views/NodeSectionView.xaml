<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="ZNext.Views.NodeSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <StackPanel Spacing="20">
            <TextBlock Text="节点状态" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center"/>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <CheckBox x:Name="HideOfflineNodesCheckBox"
                              x:FieldModifier="public"
                              Content="隐藏离线节点"
                              Checked="NodeFilterCheckBox_Changed"
                              Unchecked="NodeFilterCheckBox_Changed"/>
                    <CheckBox x:Name="HideOverloadedNodesCheckBox"
                              x:FieldModifier="public"
                              Content="隐藏过载节点"
                              Checked="NodeFilterCheckBox_Changed"
                              Unchecked="NodeFilterCheckBox_Changed"/>
                </StackPanel>
                <TextBox Grid.Column="1"
                         x:Name="NodeSearchTextBox"
                         x:FieldModifier="public"
                         Width="200"
                         PlaceholderText="搜索节点名称或 ID"
                         TextChanged="NodeSearchTextBox_TextChanged"/>
            </Grid>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14,12">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE73E;" FontFamily="{ThemeResource AppSymbolFontFamily}" FontSize="14"/>
                            <TextBlock Text="在线节点" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="StatsOnlineNodesText"
                                   Text="{Binding OnlineNodesText}"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14,12">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE77B;" FontFamily="{ThemeResource AppSymbolFontFamily}" FontSize="14"/>
                            <TextBlock Text="在线用户" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="StatsOnlineUsersText"
                                   Text="{Binding OnlineUsersText}"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14,12">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8D4;" FontFamily="{ThemeResource AppSymbolFontFamily}" FontSize="14"/>
                            <TextBlock Text="在线隧道" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="StatsOnlineTunnelsText"
                                   Text="{Binding OnlineTunnelsText}"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14,12">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8C3;" FontFamily="{ThemeResource AppSymbolFontFamily}" FontSize="14"/>
                            <TextBlock Text="今日入站流量" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="StatsTodayInText"
                                   Text="{Binding TodayInText}"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14,12">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8C7;" FontFamily="{ThemeResource AppSymbolFontFamily}" FontSize="14"/>
                            <TextBlock Text="今日出站流量" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="StatsTodayOutText"
                                   Text="{Binding TodayOutText}"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <ProgressRing x:Name="NodesLoadingProgressBar"
                          IsActive="{Binding IsLoading}"
                          Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                          Width="24"
                          Height="24"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>

            <StackPanel x:Name="NodesErrorPlaceholder"
                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Margin="0,18,0,6">
                <Image Source="ms-appx:///Assets/wifi.png"
                       Width="84"
                       Height="84"
                       Stretch="Uniform"/>
                <TextBlock Text="无法连接到服务，请检查网络"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Button Content="重试"
                        Width="96"
                        HorizontalAlignment="Center"
                        Click="RetryNodesButton_Click"/>
            </StackPanel>

            <Border x:Name="NodesTableBorder"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{Binding HasVisibleNodes, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Spacing="0">
                    <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" Padding="14,10">
                        <Grid ColumnDefinitions="2.2*,0.9*,0.9*,1.3*,1.3*,2.0*,1.5*" ColumnSpacing="14">
                            <TextBlock Text="节点" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="在线隧道" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="当前连接" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="负载百分比" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="今日流量" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="5" Text="版本" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="6" Text="运行时长" FontSize="13" FontWeight="SemiBold"/>
                        </Grid>
                    </Border>

                    <ItemsRepeater x:Name="NodesItemsRepeater"
                                   ItemsSource="{Binding VisibleNodes}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="0"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="0,1,0,0"
                                        Padding="14,10">
                                    <Grid ColumnDefinitions="2.2*,0.9*,0.9*,1.3*,1.3*,2.0*,1.5*" ColumnSpacing="14">
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                                                <TextBlock Text="#" Foreground="{ThemeResource SystemAccentColor}" FontWeight="SemiBold" FontSize="12"/>
                                                <TextBlock Text="{Binding NodeInfo.NodeId}" Foreground="{ThemeResource SystemAccentColor}" FontWeight="SemiBold" FontSize="12"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="{Binding NodeInfo.Name}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding NodeInfo.Region, Converter={StaticResource RegionCodeToTextConverter}}"
                                                           FontSize="11"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1" Text="{Binding NodeStatus.OnlineProxy}" VerticalAlignment="Center" FontSize="14"/>
                                        <TextBlock Grid.Column="2" Text="{Binding NodeStatus.CurConns}" VerticalAlignment="Center" FontSize="14"/>

                                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <ProgressBar Value="{Binding NodeStatus.LoadPercent}"
                                                         Maximum="100"
                                                         Width="90"
                                                         Height="6"
                                                         Foreground="{Binding NodeStatus.LoadPercent, Converter={StaticResource LoadToColorConverter}}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="0">
                                                <TextBlock Text="{Binding NodeStatus.LoadPercent}" FontSize="14"/>
                                                <TextBlock Text="%" FontSize="14"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="4" Spacing="3" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="▲" Foreground="#16A34A" FontSize="10" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding NodeStatus.TotalTrafficIn, Converter={StaticResource BytesToMBConverter}}" FontSize="13"/>
                                                <TextBlock Text=" MB" FontSize="13"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="▼" Foreground="#DC2626" FontSize="10" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding NodeStatus.TotalTrafficOut, Converter={StaticResource BytesToMBConverter}}" FontSize="13"/>
                                                <TextBlock Text=" MB" FontSize="13"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock Grid.Column="5"
                                                   Text="{Binding NodeStatus.Version}"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <Border Grid.Column="6"
                                                Background="{Binding NodeStatus.IsOnline, Converter={StaticResource BooleanToColorConverter}, ConverterParameter=Online}"
                                                CornerRadius="10"
                                                Padding="8,3"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding OnlineStatusText}" Foreground="White" FontSize="13"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>

            <TextBlock x:Name="NoNodesTextBlock"
                       Text="暂无节点数据"
                       FontSize="16"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</UserControl>
